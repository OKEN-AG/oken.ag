{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/core/collateral.schema.json",
  "title": "Collateral",
  "description": "Garantia associada ao deal com trilha de lifecycle e idempotência.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity", "version", "id", "tenantId", "dealId", "status", "collateralType", "currency", "createdAt"],
  "properties": {
    "entity": { "const": "collateral" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "default": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "dealId": { "type": "string", "minLength": 1 },
    "programId": { "type": "string", "minLength": 1 },
    "organizationId": { "type": "string", "minLength": 1 },
    "providerPartyId": { "type": "string", "minLength": 1 },
    "beneficiaryPartyId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["proposed", "perfected", "released", "executed", "cancelled"] },
    "collateralType": { "type": "string", "minLength": 1 },
    "referenceCode": { "type": "string" },
    "securedAmount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "idempotencyKey": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
