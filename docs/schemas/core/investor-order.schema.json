{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/core/investor-order.schema.json",
  "title": "InvestorOrder",
  "description": "Ordem de investimento emitida por parte investidora para uma oferta.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity", "version", "id", "tenantId", "offerId", "status", "orderAmount", "currency", "requestedAt", "createdAt"],
  "properties": {
    "entity": { "const": "investor_order" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "default": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "dealId": { "type": "string", "minLength": 1 },
    "programId": { "type": "string", "minLength": 1 },
    "organizationId": { "type": "string", "minLength": 1 },
    "investorPartyId": { "type": "string", "minLength": 1 },
    "offerId": { "type": "string", "minLength": 1 },
    "poolId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["pending", "confirmed", "allocated", "partially_allocated", "cancelled", "rejected", "settled"] },
    "externalOrderId": { "type": "string" },
    "orderAmount": { "type": "number", "minimum": 0 },
    "allocatedAmount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "requestedAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
