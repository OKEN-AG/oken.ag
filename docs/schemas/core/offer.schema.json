{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/core/offer.schema.json",
  "title": "Offer",
  "description": "Oferta vinculada a pool/deal/instrument para captação.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity", "version", "id", "tenantId", "status", "currency", "createdAt"],
  "properties": {
    "entity": { "const": "offer" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "default": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "dealId": { "type": "string", "minLength": 1 },
    "programId": { "type": "string", "minLength": 1 },
    "organizationId": { "type": "string", "minLength": 1 },
    "partyId": { "type": "string", "minLength": 1 },
    "poolId": { "type": "string", "minLength": 1 },
    "instrumentId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "published", "partially_subscribed", "subscribed", "withdrawn", "expired", "closed"] },
    "offerCode": { "type": "string" },
    "offeredAmount": { "type": "number", "minimum": 0 },
    "minTicket": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "publishedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
