{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/core/offer.schema.json",
  "title": "Offer",
  "description": "Oferta primária/secundária de instrumentos no tenant.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity", "version", "id", "tenantId", "programId", "offerCode", "status", "offeredAmount", "currency", "createdAt"],
  "properties": {
    "entity": { "const": "offer" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "default": "1.0.0" },
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "programId": { "type": "string", "format": "uuid" },
    "dealId": { "type": "string", "format": "uuid" },
    "poolId": { "type": "string", "format": "uuid" },
    "instrumentId": { "type": "string", "format": "uuid" },
    "offerCode": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "open", "partially_filled", "filled", "cancelled", "expired"] },
    "offeredAmount": { "type": "number", "minimum": 0 },
    "minTicket": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "opensAt": { "type": "string", "format": "date-time" },
    "closesAt": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "default": {} },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
