{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/core/instrument.schema.json",
  "title": "Instrument",
  "description": "Instrumento financeiro canônico vinculado ao programa e ao deal.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity", "version", "id", "tenantId", "programId", "status", "instrumentCode", "instrumentType", "currency", "createdAt"],
  "properties": {
    "entity": { "const": "instrument" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "default": "1.0.0" },
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "programId": { "type": "string", "format": "uuid" },
    "dealId": { "type": "string", "format": "uuid" },
    "instrumentCode": { "type": "string", "minLength": 1 },
    "instrumentType": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "suspended", "matured", "cancelled"] },
    "notionalAmount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "issuedAt": { "type": "string", "format": "date-time" },
    "maturityDate": { "type": "string", "format": "date" },
    "metadata": { "type": "object", "default": {} },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
