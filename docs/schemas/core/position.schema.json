{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/core/position.schema.json",
  "title": "Position",
  "description": "Posição financeira por instrumento/parte no tenant.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity", "version", "id", "tenantId", "status", "positionDate", "currency", "createdAt"],
  "properties": {
    "entity": { "const": "position" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "default": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "dealId": { "type": "string", "minLength": 1 },
    "programId": { "type": "string", "minLength": 1 },
    "organizationId": { "type": "string", "minLength": 1 },
    "partyId": { "type": "string", "minLength": 1 },
    "instrumentId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["open", "partially_closed", "closed", "liquidated", "cancelled"] },
    "quantity": { "type": "number", "minimum": 0 },
    "grossAmount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "positionDate": { "type": "string", "format": "date" },
    "idempotencyKey": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
