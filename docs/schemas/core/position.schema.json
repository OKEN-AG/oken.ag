{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/core/position.schema.json",
  "title": "Position",
  "description": "Posição consolidada por holder/instrumento no ciclo da operação.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity", "version", "id", "tenantId", "programId", "positionRef", "status", "quantity", "currency", "createdAt"],
  "properties": {
    "entity": { "const": "position" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "default": "1.0.0" },
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "programId": { "type": "string", "format": "uuid" },
    "dealId": { "type": "string", "format": "uuid" },
    "instrumentId": { "type": "string", "format": "uuid" },
    "investorOrderId": { "type": "string", "format": "uuid" },
    "holderPartyId": { "type": "string", "format": "uuid" },
    "positionRef": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["pending", "open", "partially_closed", "closed", "defaulted"] },
    "quantity": { "type": "number", "minimum": 0 },
    "unitPrice": { "type": "number", "minimum": 0 },
    "grossValue": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "metadata": { "type": "object", "default": {} },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
