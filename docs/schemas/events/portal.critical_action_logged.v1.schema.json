{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/events/portal.critical_action_logged.v1.schema.json",
  "title": "portal.critical_action_logged.v1",
  "description": "Evento emitido quando uma ação crítica é registrada no portal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "occurred_at",
    "producer",
    "schema_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action_type",
        "actor_id",
        "logged_at"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "format": "uuid"
        },
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "logged_at": {
          "type": "string",
          "format": "date-time"
        },
        "entity_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
