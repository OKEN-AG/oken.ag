{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/events/deals.deal_approved.v1.schema.json",
  "title": "deals.deal_approved.v1",
  "type": "object",
  "required": ["event_id", "occurred_at", "producer", "schema_version", "dedupe_key", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "const": "deals" },
    "schema_version": { "const": "v1" },
    "dedupe_key": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["deal_id", "approval_id", "approved_by", "approved_at"],
      "properties": {
        "deal_id": { "type": "string" },
        "approval_id": { "type": "string" },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" },
        "deal_snapshot_ref": { "type": "string" }
      }
    }
  }
}
