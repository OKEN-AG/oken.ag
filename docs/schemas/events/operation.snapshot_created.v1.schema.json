{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/events/operation.snapshot_created.v1.schema.json",
  "title": "operation.snapshot_created.v1",
  "description": "Evento emitido quando um snapshot operacional é persistido.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "occurred_at",
    "producer",
    "schema_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "snapshot_id",
        "snapshot_at",
        "reason"
      ],
      "properties": {
        "operation_id": {
          "type": "string",
          "format": "uuid"
        },
        "snapshot_id": {
          "type": "string",
          "format": "uuid"
        },
        "snapshot_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "enum": [
            "checkpoint",
            "manual",
            "automated"
          ]
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
