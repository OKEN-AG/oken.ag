{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oken.ag/schemas/events/operation.step_completed.v1.schema.json",
  "title": "operation.step_completed.v1",
  "description": "Evento emitido na conclusão de uma etapa operacional.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "occurred_at",
    "producer",
    "schema_version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "step",
        "completed_at",
        "status"
      ],
      "properties": {
        "operation_id": {
          "type": "string",
          "format": "uuid"
        },
        "step": {
          "type": "string",
          "minLength": 1
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "skipped"
          ]
        },
        "operator_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
